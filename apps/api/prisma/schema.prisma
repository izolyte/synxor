generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoomStatus {
  ACTIVE
  CLOSED
  EXPIRED
}

enum ParticipantRole {
  SENDER
  RECEIVER
}

enum PayloadType {
  FILE
  TEXT_SNIPPET
  LINK
}

model Room {
  id        String     @id @default(cuid())
  code      String     @unique
  status    RoomStatus @default(ACTIVE)
  expiresAt DateTime
  createdAt DateTime   @default(now())

  participants Participant[]
  transfers    Transfer[]

  @@index([status])
  @@index([expiresAt])
}

model Participant {
  id             String          @id @default(cuid())
  roomId         String
  role           ParticipantRole
  // Not unique: a Participant row is one connection, not one token. The same
  // token reconnects (refresh, socket.io retry) as a fresh row, so the hash
  // repeats across a session — kept only as an audit trail of who joined.
  tokenHash      String
  joinedAt       DateTime        @default(now())
  disconnectedAt DateTime?

  room Room @relation(fields: [roomId], references: [id])

  @@index([roomId])
}

model Transfer {
  id            String      @id @default(cuid())
  roomId        String
  payloadType   PayloadType
  contentLength BigInt
  createdAt     DateTime    @default(now())

  room        Room         @relation(fields: [roomId], references: [id])
  filePayload FilePayload?
  textPayload TextPayload?
  delivery    Delivery?

  @@index([roomId])
}

model FilePayload {
  id            String @id @default(cuid())
  transferId    String @unique
  fileName      String
  fileSizeBytes BigInt
  mimeType      String
  storageKey    String

  transfer Transfer @relation(fields: [transferId], references: [id])
}

// A persisted Text Snippet or Link. Files land in object storage via
// FilePayload; text is small and structured, so it lives inline in Postgres —
// the whole point is that it survives reload and late-join like a file does.
model TextPayload {
  id         String   @id @default(cuid())
  transferId String   @unique
  content    String
  createdAt  DateTime @default(now())

  transfer Transfer @relation(fields: [transferId], references: [id])
}

model Delivery {
  id          String   @id @default(cuid())
  transferId  String   @unique
  deliveredAt DateTime
  createdAt   DateTime @default(now())

  transfer Transfer @relation(fields: [transferId], references: [id])
}
