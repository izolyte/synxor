# API
API_PORT=3000
# HTTP CORS allowlist — comma-separated origins. Unset = allow any in dev,
# but required when NODE_ENV=production (the server refuses to default to "*").
ALLOWED_ORIGINS=https://app.synxor.io
# Socket.io CORS allowlist — same rules as ALLOWED_ORIGINS; usually the same list.
WS_ALLOWED_ORIGINS=https://app.synxor.io
# Room Token signing secret — at least 32 bytes, e.g. `openssl rand -base64 48`
JWT_SECRET=changeme-generate-a-random-48-byte-secret

# PostgreSQL
POSTGRES_USER=synxor
POSTGRES_PASSWORD=changeme
POSTGRES_DB=synxor
# Computed from POSTGRES_* above — keep in sync manually
DATABASE_URL=postgresql://synxor:changeme@postgres:5432/synxor

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_BUCKET=transfers

# Redis — docker compose overrides this to redis://redis:6379 in-network;
# this value is for tooling running on the host against the exposed port.
REDIS_URL=redis://localhost:6379

# File transfer
MAX_FILE_SIZE_BYTES=5368709120
