# API
# Port the NestJS server listens on inside its container. Not published to the
# host — the nginx proxy reaches it over the internal network.
API_PORT=3000
# HTTP CORS allowlist — comma-separated origins. Unset = allow any in dev,
# but required when NODE_ENV=production (the server refuses to default to "*").
# The browser now talks to the proxy origin, so list that (not the api port).
ALLOWED_ORIGINS=https://localhost
# Socket.io CORS allowlist — same rules as ALLOWED_ORIGINS; usually the same list.
WS_ALLOWED_ORIGINS=https://localhost

# Web (SSR frontend container)
# Public origin baked into the client bundle at build time. With nginx fronting
# the stack this is the proxy's HTTPS origin — the api and web share it via
# path-based routing, so tRPC, uploads, downloads, and sockets all resolve here.
VITE_API_URL=https://localhost
# Room Token signing secret — at least 32 bytes, e.g. `openssl rand -base64 48`
JWT_SECRET=changeme-generate-a-random-48-byte-secret

# Edge proxy (nginx) — the only ingress; terminates TLS and routes to api/web.
HTTP_PORT=80
HTTPS_PORT=443
# Cert + key paths inside the nginx container. Local dev uses the self-signed
# pair from `sh nginx/certs/generate-dev-cert.sh`; point these at real certs in
# production (see nginx/README.md).
TLS_CERT_PATH=/etc/nginx/certs/dev.crt
TLS_KEY_PATH=/etc/nginx/certs/dev.key

# PostgreSQL
POSTGRES_USER=synxor
POSTGRES_PASSWORD=changeme
POSTGRES_DB=synxor
# Computed from POSTGRES_* above — keep in sync manually
DATABASE_URL=postgresql://synxor:changeme@postgres:5432/synxor

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_BUCKET=transfers

# Redis — docker compose overrides this to redis://redis:6379 in-network;
# this value is for tooling running on the host against the exposed port.
REDIS_URL=redis://localhost:6379

# File transfer
MAX_FILE_SIZE_BYTES=5368709120
